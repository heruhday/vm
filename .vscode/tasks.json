{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo run example fib_compute_recursive (release)",
      "type": "shell",
      "command": "cargo",
      "args": [
        "run",
        "--release",
        "--package",
        "vm",
        "--example",
        "fib_compute_recursive"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$rustc"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "cargo run example fib_compute (release)",
      "type": "shell",
      "command": "cargo",
      "args": [
        "run",
        "--release",
        "--package",
        "vm",
        "--example",
        "fib_compute"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$rustc"
      ]
    }
  ]
}
